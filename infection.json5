{
  "source": {
    "directories": [
      "src"
    ]
  },
  "timeout": 10,
  "logs": {
    "text": "continuous-integration/infection/infection.log",
    "summary": "continuous-integration/infection/summary.log",
    "perMutator": "continuous-integration/infection/per-mutator.md"
  },
  "phpUnit": {
    "configDir": "continuous-integration/phpunit"
  },
  "testFramework": "phpunit",
  "initialTestsPhpOptions": "-d xdebug.mode=coverage"
}
